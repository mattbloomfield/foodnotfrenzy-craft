{% extends "_layout/base.twig" %}

{% block title %}
	{{ siteName }}
{% endblock %}

{% block content %}
	<div
		class="max-w-6xl mx-auto">
		<!-- Search Block -->
		<section class="mb-8">
			{% include "_components/search" %}
		</section>

		<!-- Category Selection Block for Home Page -->
		<section class="mb-12">
			<h2 class="text-xs uppercase tracking-widest text-warm-brown mb-4">Browse by Category</h2>

			<div class="flex flex-wrap gap-2">
				{% set topLevelCategories = craft.entries.section('categories').level(1).all() %}
				{% for category in topLevelCategories %}
					<a href="{{ category.url }}" class="bg-cream hover:bg-stone/50 transition duration-200 rounded-full px-4 py-2 text-sm text-warm-brown border border-stone">
						{{ category.title }}
					</a>
				{% endfor %}
			</div>
		</section>

		<!-- Recent Recipes Heading -->
		<h1 class="text-3xl font-bold font-serif text-warm-brown mb-8 pb-2 border-b-2 border-clay">All Recipes</h1>

		<!-- Recipe Grid -->
		{% set recipes = craft.entries.section('recipes').orderBy('title ASC').all() %}
		{% set gridItems = [] %}
		{% for recipe in recipes %}
			{% set categories = [] %}
			{% for category in recipe.categories.all() %}
				{% set categories = categories|merge([{
                    title: category.title,
                    href: category.url,
                }]) %}
			{% endfor %}
			{% set gridItems = gridItems|merge([{
                type: '@card/recipe',
                data: {
                    title: recipe.title,
                    href: recipe.url,
                    image: recipe.image.one() ? recipe.image.one() : null,
                    description: recipe.description,
                    categories: categories,
                },
            }]) %}
		{% endfor %}
		{% include "@listing/grid" with {
            items: gridItems,
        } %}

	</div>
{% endblock %}
