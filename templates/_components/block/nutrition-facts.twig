{% if entry.nutritionCalories is defined and entry.nutritionCalories is not null %}
{% set scale = scale|default(1) %}
<section class="my-10">
    <div class="border-2 border-warm-brown max-w-sm p-4">
        {# Header #}
        <h3 class="text-2xl font-serif font-black text-warm-brown mb-0">Nutrition Facts</h3>
        {% if entry.servings %}
            <p class="text-sm text-gray-600 mt-1">Per serving (1 of {{ entry.servings }})</p>
        {% endif %}
        {% if scale > 1 %}
            <p class="text-xs text-clay font-medium mt-1">Scaled {{ scale }}x</p>
        {% endif %}

        <div class="border-t-8 border-warm-brown mt-2 pt-1">
            {# Calories - hero row #}
            <div class="flex justify-between items-baseline pb-1 mb-1 border-b-4 border-warm-brown">
                <span class="text-sm font-bold text-gray-800">Calories</span>
                <span class="text-3xl font-serif font-black text-gray-800">{{ (entry.nutritionCalories * scale)|round }}</span>
            </div>

            {# Daily Value header #}
            <div class="text-xs text-right font-bold text-gray-800 mb-1">
                % Daily Value*
            </div>

            {# Nutrient rows #}
            {% macro nutrientRow(label, value, unit, dailyValue, indent) %}
                <div class="flex justify-between items-baseline py-0.5 border-t border-gray-300 {{ indent ? 'pl-5' : '' }}">
                    <span class="{{ indent ? 'text-gray-600' : '' }}">
                        {% if not indent %}<span class="font-bold text-gray-800">{{ label }}</span>{% else %}{{ label }}{% endif %}
                        <span class="text-gray-600">{{ value }}{{ unit }}</span>
                    </span>
                    {% if dailyValue is not null %}
                        <span class="font-bold text-gray-800 ml-4 shrink-0">{{ dailyValue }}%</span>
                    {% endif %}
                </div>
            {% endmacro %}

            {{ _self.nutrientRow('Total Fat', (entry.nutritionFat * scale)|round(1), 'g', ((entry.nutritionFat * scale) / 78 * 100)|round, false) }}

            {% if entry.nutritionSaturatedFat is defined and entry.nutritionSaturatedFat is not null %}
                {{ _self.nutrientRow('Saturated Fat', (entry.nutritionSaturatedFat * scale)|round(1), 'g', ((entry.nutritionSaturatedFat * scale) / 20 * 100)|round, true) }}
            {% endif %}

            {% if entry.nutritionSodium is defined and entry.nutritionSodium is not null %}
                {{ _self.nutrientRow('Sodium', (entry.nutritionSodium * scale)|round, 'mg', ((entry.nutritionSodium * scale) / 2300 * 100)|round, false) }}
            {% endif %}

            {% if entry.nutritionCarbs is defined and entry.nutritionCarbs is not null %}
                {{ _self.nutrientRow('Total Carbs', (entry.nutritionCarbs * scale)|round(1), 'g', ((entry.nutritionCarbs * scale) / 275 * 100)|round, false) }}
            {% endif %}

            {% if entry.nutritionFiber is defined and entry.nutritionFiber is not null %}
                {{ _self.nutrientRow('Dietary Fiber', (entry.nutritionFiber * scale)|round(1), 'g', ((entry.nutritionFiber * scale) / 28 * 100)|round, true) }}
            {% endif %}

            {% if entry.nutritionSugar is defined and entry.nutritionSugar is not null %}
                {{ _self.nutrientRow('Total Sugars', (entry.nutritionSugar * scale)|round(1), 'g', null, true) }}
            {% endif %}

            {% if entry.nutritionProtein is defined and entry.nutritionProtein is not null %}
            <div class="flex justify-between items-baseline py-0.5 border-t-8 border-warm-brown mt-1">
                <span>
                    <span class="font-bold text-gray-800">Protein</span>
                    <span class="text-gray-600">{{ (entry.nutritionProtein * scale)|round(1) }}g</span>
                </span>
                <span class="font-bold text-gray-800 ml-4 shrink-0">{{ ((entry.nutritionProtein * scale) / 50 * 100)|round }}%</span>
            </div>
            {% endif %}

            {# Footer #}
            <p class="text-xs text-gray-500 mt-2 pt-2 border-t border-gray-300 leading-relaxed">
                * Percent Daily Values are based on a 2,000 calorie diet.
            </p>
        </div>
    </div>
</section>
{% endif %}
