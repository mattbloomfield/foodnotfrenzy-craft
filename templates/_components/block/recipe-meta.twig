<div class="recipe-meta border-y border-stone my-8 py-5">

<!-- Time + metadata in a single horizontal bar -->
    <div class="flex flex-wrap justify-center items-center gap-x-8 gap-y-4">
        <!-- Prep Time -->
        {% if entry.prepTime is not null %}
        <div class="flex flex-col items-center">
            <span class="text-xs uppercase tracking-wider text-warm-brown/70 font-medium">Prep</span>
            <span class="text-lg font-serif font-bold text-warm-brown">{{ entry.prepTime|formatMinutes }}</span>
        </div>
        {% endif %}

        {% if entry.idleTime is not null %}
            <div class="flex flex-col items-center">
                <span class="text-xs uppercase tracking-wider text-warm-brown/70 font-medium">Idle</span>
                <span class="text-lg font-serif font-bold text-warm-brown">{{ entry.idleTime|formatMinutes }}</span>
            </div>
        {% endif %}

        <!-- Cook Time -->
        {% if entry.cookTime is not null %}
        <div class="flex flex-col items-center">
            <span class="text-xs uppercase tracking-wider text-warm-brown/70 font-medium">Cook</span>
            <span class="text-lg font-serif font-bold text-warm-brown">{{ entry.cookTime|formatMinutes }}</span>
        </div>
        {% endif %}

        <!-- Total Time -->
        {% if entry.cookTime is not null or entry.prepTime is not null or entry.idleTime is not null %}
        <div class="flex flex-col items-center">
            <span class="text-xs uppercase tracking-wider text-warm-brown/70 font-medium">Total</span>
            <span class="text-lg font-serif font-bold text-warm-brown">{{ (entry.cookTime|default(0) + entry.prepTime|default(0) + entry.idleTime|default(0))|formatMinutes }}</span>
        </div>
        {% endif %}

        <!-- Servings -->
        {% if entry.servings is defined and entry.servings %}
            <div class="flex flex-col items-center">
                <span class="text-xs uppercase tracking-wider text-warm-brown/70 font-medium">Servings</span>
                <span class="text-lg font-serif font-bold text-warm-brown">{{ entry.servings * scale }}</span>
            </div>
        {% endif %}

        <!-- Yield -->
        {% if entry.yield is defined and entry.yield %}
            <div class="flex flex-col items-center">
                <span class="text-xs uppercase tracking-wider text-warm-brown/70 font-medium">Yield</span>
                <span class="text-lg font-serif font-bold text-warm-brown">{{ entry.yield * scale }}</span>
            </div>
        {% endif %}

        <!-- Difficulty -->
        {% if entry.difficulty is defined and entry.difficulty.value is not null %}
            <div class="flex flex-col items-center">
                <span class="text-xs uppercase tracking-wider text-warm-brown/70 font-medium">Difficulty</span>
                <span class="text-lg font-serif font-bold text-warm-brown">{{ entry.difficulty|capitalize }}</span>
            </div>
        {% endif %}
    </div>
</div>
