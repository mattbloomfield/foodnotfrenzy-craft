<a href="{{ href }}" class="group">
	<article class="bg-cream rounded-lg overflow-hidden h-full transition duration-200">
		<div class="aspect-w-16 aspect-h-9 overflow-hidden">
			{% set card = {
                mode: 'crop',
                width: 352,
                height: 264,
                quality: 75,
                position: 'center-center'
            } %}
			{% if image is not null %}
				<img src="{{ image.getUrl(card) }}" width="{{ image.getWidth(card) }}" height="{{ image.getHeight(card) }}" alt="{{ title }}" class="object-cover w-full h-full group-hover:scale-[1.02] transition-transform duration-500 ease-out">
			{% else %}
				<img src="/dist/placeholder.jpg" alt="Placeholder Image" class="object-cover w-full h-full group-hover:scale-[1.02] transition-transform duration-500 ease-out" style="width: 352px; height: 264px;">
			{% endif %}
		</div>

		<div class="p-4">
			<h2 class="text-xl font-bold font-serif text-warm-brown group-hover:text-clay transition duration-200">{{ title }}</h2>

			{% if description %}
				<p class="mt-2 text-gray-700 line-clamp-2">{{ description }}</p>
			{% endif %}

			{% if categories|length %}
				<p class="mt-3 text-sm text-sage">
					{% for category in categories %}{{ category.title }}{% if not loop.last %} &middot; {% endif %}{% endfor %}
				</p>
			{% endif %}
            {# post date #}
            {% if date is defined %}
                <p class="mt-4 text-gray-400 text-xs">Added on {{ date|date('F j, Y') }} at {{ date|date('g:i a') }}</p>
            {% endif %}
		</div>
	</article>
</a>
