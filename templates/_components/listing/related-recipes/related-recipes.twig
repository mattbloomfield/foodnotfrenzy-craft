<div class="hidden md:block sticky top-6">
    <h2 class="text-xs uppercase tracking-widest text-warm-brown mb-4">You Might Also Like</h2>

    <div class="space-y-6">
        {% for relatedRecipe in entry.relatedRecipes.all() %}
            <a href="{{ relatedRecipe.url }}" class="group block">
                <article class="flex flex-col">
                    {% if relatedRecipe.image.one() %}
                        <div class="rounded-lg overflow-hidden mb-3">
                            <img src="{{ relatedRecipe.image.one().url }}" alt="{{ relatedRecipe.title }}" class="object-cover w-full h-32 group-hover:scale-[1.02] transition-transform duration-500 ease-out">
                        </div>
                    {% endif %}

                    <h3 class="font-bold font-serif text-warm-brown group-hover:text-clay transition duration-200">{{ relatedRecipe.title }}</h3>

                    {% if relatedRecipe.description %}
                        <p class="mt-1 text-sm text-gray-700 line-clamp-2">{{ relatedRecipe.description }}</p>
                    {% endif %}
                </article>
            </a>

            {% if not loop.last %}
                <div class="border-b border-stone/50"></div>
            {% endif %}
        {% endfor %}
    </div>
</div>
