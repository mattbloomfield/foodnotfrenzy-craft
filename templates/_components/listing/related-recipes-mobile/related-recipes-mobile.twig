<div class="md:hidden mt-12">
    <h2 class="text-xs uppercase tracking-widest text-warm-brown mb-6">You Might Also Like</h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {% for relatedRecipe in entry.relatedRecipes.all() %}
            <a href="{{ relatedRecipe.url }}" class="group">
                <article class="bg-cream rounded-lg overflow-hidden h-full transition duration-200">
                    {% if relatedRecipe.image.one() %}
                        <div class="aspect-w-16 aspect-h-9 overflow-hidden">
                            <img src="{{ relatedRecipe.image.one().url }}" alt="{{ relatedRecipe.title }}" class="object-cover w-full h-full group-hover:scale-[1.02] transition-transform duration-500 ease-out">
                        </div>
                    {% else %}
                        <div class="aspect-w-16 aspect-h-9 bg-stone/20 flex items-center justify-center">
                            <span class="text-warm-brown font-serif">No image</span>
                        </div>
                    {% endif %}

                    <div class="p-4">
                        <h3 class="text-lg font-bold font-serif text-warm-brown group-hover:text-clay transition duration-200">{{ relatedRecipe.title }}</h3>

                        {% if relatedRecipe.description %}
                            <p class="mt-2 text-gray-700 line-clamp-2">{{ relatedRecipe.description }}</p>
                        {% endif %}
                    </div>
                </article>
            </a>
        {% endfor %}
    </div>
</div>
